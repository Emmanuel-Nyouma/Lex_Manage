generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  email       String?
  phone       String?
  address     String?
  type_client String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("clients")
}

model Tenant {
  id            String             @id @default(uuid())
  name          String
  slug          String             @unique
  plan          String             @default("FREE")
  country       String?
  city          String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  auditLogs     AuditLog[]
  cases         Case[]
  conversations ChatConversation[]
  clients       Client[]
  deadlines     Deadline[]
  documents     Document[]
  invitations   Invitation[]
  notifications Notification[]
  users         User[]

  @@map("tenants")
}

model User {
  id                    String             @id @default(uuid())
  tenantId              String             @map("tenant_id")
  email                 String             @unique
  passwordHash          String             @map("password_hash")
  firstName             String             @map("first_name")
  lastName              String             @map("last_name")
  phone                 String?
  role                  Role               @default(LAWYER)
  barreau               String?            @map("barreau")
  specialty             String?            @map("specialty")
  isActive              Boolean            @default(true) @map("is_active")
  avatarUrl             String?            @map("avatar_url")
  refreshToken          String?            @map("refresh_token")
  refreshTokenExpiresAt DateTime?          @map("refresh_token_expires_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  auditLogs             AuditLog[]
  cases                 Case[]             @relation("CaseAssignee")
  conversations         ChatConversation[]
  documents             Document[]         @relation("DocumentUploader")
  notifications         Notification[]
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

model Invitation {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  email     String
  role      Role     @default(LAWYER)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
  @@map("invitations")
}

model Case {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  title       String
  description String?
  clientName  String     @map("client_name")
  caseNumber  String?    @map("case_number")
  courtName   String?    @map("court_name")
  status      CaseStatus @default(OPEN)
  priority    String     @default("MEDIUM")
  assigneeId  String?    @map("assignee_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  closedAt    DateTime?  @map("closed_at")
  assignee    User?      @relation("CaseAssignee", fields: [assigneeId], references: [id])
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deadlines   Deadline[]
  documents   Document[]

  @@index([tenantId])
  @@index([status])
  @@map("cases")
}

model Document {
  id         String         @id @default(uuid())
  tenantId   String         @map("tenant_id")
  caseId     String?        @map("case_id")
  uploaderId String         @map("uploader_id")
  title      String
  category   String?
  fileName   String         @map("file_name")
  fileUrl    String         @map("file_url")
  fileType   String         @map("file_type")
  fileSize   Int            @map("file_size")
  status     DocumentStatus @default(UPLOADED)
  qdrantId   String?        @map("qdrant_id")
  createdAt  DateTime       @default(now()) @map("created_at")
  case       Case?          @relation(fields: [caseId], references: [id])
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploader   User           @relation("DocumentUploader", fields: [uploaderId], references: [id])

  @@index([tenantId])
  @@index([caseId])
  @@map("documents")
}

model ChatConversation {
  id        String        @id @default(uuid())
  tenantId  String        @map("tenant_id")
  userId    String        @map("user_id")
  title     String        @default("Nouvelle conversation")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])
  messages  ChatMessage[]

  @@index([tenantId])
  @@index([userId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  role           String
  content        String
  sources        Json?
  createdAt      DateTime         @default(now()) @map("created_at")
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chat_messages")
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  action    String
  entity    String
  entityId  String   @map("entity_id")
  details   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@map("audit_logs")
}

model Deadline {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  caseId    String   @map("case_id")
  title     String
  dueAt     DateTime @map("due_at")
  priority  String   @default("MEDIUM")
  isDone    Boolean  @default(false) @map("is_done")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([caseId])
  @@map("deadlines")
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  title     String
  message   String
  priority  String   @default("MEDIUM")
  isRead    Boolean  @default(false) @map("is_read")
  type      String?  @map("type")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("notifications")
}

enum Role {
  SUPER_ADMIN
  CABINET_ADMIN
  LAWYER
  ASSISTANT
  SECRETARY
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  PENDING
  CLOSED
  ARCHIVED
}

enum DocumentStatus {
  UPLOADED
  OCR_PENDING
  OCR_DONE
  INDEXED
  ERROR
}
