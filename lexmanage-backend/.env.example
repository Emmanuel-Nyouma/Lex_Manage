# Backend Environment Configuration
# Copy to .env and fill in real values — do NOT commit .env

# --- Database ---
DATABASE_URL="postgresql://postgres:change_me_immediately@localhost:5432/lexmanage"

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_USE_A_LONG_RANDOM_SECRET"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# --- App ---
PORT=3001
NODE_ENV=development
# Comma-separated — must NOT contain localhost in production
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# --- Redis (BullMQ — required) ---
REDIS_HOST=localhost
REDIS_PORT=6379
# Managed Redis (Upstash / Render Key Value) — leave empty for local MinIO/Redis
REDIS_PASSWORD=
REDIS_TLS=false

# --- Object storage (S3-compatible: Supabase / MinIO / Storj / iDrive e2) ---
# Local MinIO container:  http://localhost:9000
# Supabase Storage:       https://<project-ref>.supabase.co/storage/v1/s3
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
# Change from defaults before deploying
S3_ACCESS_KEY="change_me_storage_user"
S3_SECRET_KEY="change_me_storage_password"
# Bucket must be pre-created on managed providers (e.g. Supabase dashboard)
S3_BUCKET="lexmanage-documents"

# --- Gemini AI ---
GEMINI_API_KEY="your_gemini_api_key_here"

# --- n8n RAG Webhooks (optional — AI assistant is disabled if unset) ---
N8N_RAG_CHAT_URL=""
N8N_RAG_INGEST_URL=""

# --- Email / Resend (optional — email notifications disabled if unset) ---
RESEND_API_KEY=""
MAIL_FROM="onboarding@resend.dev"
