# ==============================================================================
# LexManage Environment Configuration Example
# Copy this file to .env and fill in the values.
# DO NOT commit the .env file to version control!
# ==============================================================================

# --- Database Configuration ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_immediately
POSTGRES_DB=lexmanage

# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
# When using docker-compose, HOST should be 'postgres' (the service name)
DATABASE_URL=postgresql://postgres:change_me_immediately@postgres:5432/lexmanage

# --- Backend Configuration ---
PORT=3001
NODE_ENV=production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Comma-separated — must NOT contain localhost in production
ALLOWED_ORIGINS=https://your-frontend-domain.com

# --- Redis (required for BullMQ background jobs) ---
REDIS_HOST=redis
REDIS_PORT=6379
# Managed Redis (Upstash / Render Key Value) — leave empty for the local container
REDIS_PASSWORD=
REDIS_TLS=false

# --- Object storage (S3-compatible: Supabase / MinIO / Storj / iDrive e2) ---
# Local MinIO container:  http://minio:9000
# Supabase Storage:       https://<project-ref>.supabase.co/storage/v1/s3
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
# Change from the defaults before deploying
S3_ACCESS_KEY=change_me_storage_user
S3_SECRET_KEY=change_me_storage_password
# Bucket must be pre-created on managed providers (e.g. Supabase dashboard)
S3_BUCKET=lexmanage-documents

# --- Gemini AI ---
# Get your API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- n8n RAG Webhooks (optional — AI assistant is disabled if unset) ---
N8N_RAG_CHAT_URL=https://your-n8n-instance/webhook/rag-chat
N8N_RAG_INGEST_URL=https://your-n8n-instance/webhook/rag-ingest

# --- Email / Resend (optional — email notifications disabled if unset) ---
# Get your API key from https://resend.com/
RESEND_API_KEY=re_your_resend_api_key
# Must be a Resend-verified domain in production
MAIL_FROM=noreply@your-verified-domain.com

# --- Frontend Configuration ---
VITE_APP_TITLE=LexManage
VITE_ENABLE_AI=true
VITE_SECURE_AUTH=true

# Dockerized deploy (docker compose): the frontend's own public origin. nginx
# serves the SPA here and proxies /api + /socket.io to the backend (same-origin).
FRONTEND_PUBLIC_URL=https://app.your-domain.com
# Optional host port for the frontend container (default 80)
# FRONTEND_PORT=80

# Non-docker / separate-backend-domain builds use these directly instead.
# (Vite inlines them at build time.) Point at the backend's public URL.
VITE_API_URL=https://api.your-domain.com
VITE_WS_URL=https://api.your-domain.com
